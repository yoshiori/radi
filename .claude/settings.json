{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "postWrite": [
      {
        "matcher": "**/*.rs",
        "command": "cargo fmt && cargo clippy -- -D warnings"
      }
    ],
    "postEdit": [
      {
        "matcher": "**/*.rs",
        "command": "cargo fmt && cargo clippy -- -D warnings"
      }
    ],
    "postNotebookEdit": [
      {
        "matcher": "**/*.rs",
        "command": "cargo fmt && cargo clippy -- -D warnings"
      }
    ]
  }
}
